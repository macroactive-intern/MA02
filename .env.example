# Application
APP_NAME=MacroTargetCalculator
APP_ENV=local                   # Set to 'production' on live servers
APP_KEY=                        # Run: php artisan key:generate
APP_DEBUG=true                  # MUST be false in production — exposes stack traces
APP_URL=http://localhost:8000   # Full URL of the application

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Security
BCRYPT_ROUNDS=12                # Cost factor for password hashing — increase for higher security (slower)

# Logging
# Use 'json' channel in production for structured, parseable log output
LOG_CHANNEL=stack
LOG_STACK=single                # Set to 'json' in production
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                 # Set to 'error' or 'warning' in production

# Database
# Local: use sqlite (no setup required)
# Production: use mysql or pgsql — SQLite is not suitable for production
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1             # Required for mysql/pgsql
# DB_PORT=3306                  # 3306 for mysql, 5432 for pgsql
# DB_DATABASE=macro_targets     # Database name
# DB_USERNAME=root              # Database username
# DB_PASSWORD=                  # Database password

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120            # Minutes before session expires
SESSION_ENCRYPT=false           # Set to true in production for encrypted sessions

# CORS
# Comma-separated list of allowed origins. Never use '*' in production.
# Example: https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cache / Queue
CACHE_STORE=database
QUEUE_CONNECTION=database

# Mail (not used by this application — safe to leave as defaults)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
